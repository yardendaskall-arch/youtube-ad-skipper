javascript:(function(){if(document.getElementById('yyp'))return;const d=document,v=()=>d.querySelector('video'),g=d.createElement('div');g.id='yyp';Object.assign(g.style,{background:'rgba(10,10,10,0.95)',backdropFilter:'blur(12px)',color:'#fff',padding:'12px',borderRadius:'16px',position:'fixed',top:'80px',right:'30px',zIndex:'9999',width:'180px',border:'1px solid #333',cursor:'grab',fontFamily:'sans-serif'});const h=d.createElement('b');h.textContent='YAPA YIPI ELITE 🚀';Object.assign(h.style,{display:'block',textAlign:'center',color:'#f44',fontSize:'12px',marginBottom:'8px'});const btn=(t,c,f)=>{const b=d.createElement('button');b.textContent=t;Object.assign(b.style,{width:'100%',margin:'3px 0',padding:'6px',background:c,color:'#fff',border:'none',borderRadius:'6px',fontSize:'10px',fontWeight:'bold',cursor:'pointer'});b.onclick=f;return b;};const p=btn('⏯ PLAY/PAUSE','#333',()=>d.querySelector('.ytp-play-button')?.click());const s=btn('⏭ SKIP AD','#e60',()=>d.querySelector('.ytp-ad-skip-button-modern,.ytp-skip-ad-button')?.click());const cap=btn('📸 SCREENSHOT','#4a9',()=>{const m=v(),c=d.createElement('canvas');c.width=m.videoWidth;c.height=m.videoHeight;c.getContext('2d').drawImage(m,0,0);const a=d.createElement('a');a.href=c.toDataURL();a.download='yyp.png';a.click()});const th=btn('🎭 THEATER','#555',()=>d.querySelector('.ytp-size-button')?.click());const sl=d.createElement('input');sl.type='range';sl.min=0.5;sl.max=4;sl.step=0.25;sl.value=1;sl.style.width='100%';const chk=d.createElement('input');chk.type='checkbox';chk.checked=true;const l=d.createElement('label');l.append(chk,' AUTO-SKIP');l.style.fontSize='10px';const x=d.createElement('div');x.textContent='✕';Object.assign(x.style,{position:'absolute',top:'4px',right:'8px',cursor:'pointer',color:'#777'});x.onclick=()=>g.remove();g.append(x,h,p,s,cap,th,sl,l);d.body.appendChild(g);let o1,o2,o3,o4;g.onmousedown=e=>{if(e.target!==g)return;o3=e.clientX;o4=e.clientY;d.onmouseup=()=>d.onmousemove=null;d.onmousemov